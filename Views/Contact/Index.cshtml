@{
    ViewData["Title"] = "Contact - Things Done Immediately";
}

<style>
    .contact-hero {
        background: linear-gradient(135deg, var(--tdi-dark) 0%, var(--tdi-darker) 100%);
        padding: 150px 0 100px;
        text-align: center;
    }

    .contact-methods {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        margin: 50px 0;
    }

    .contact-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--tdi-gray);
        border-radius: 15px;
        padding: 40px 30px;
        text-align: center;
        transition: all 0.3s ease;
        height: 100%;
    }

        .contact-card:hover {
            border-color: var(--tdi-accent);
            transform: translateY(-5px);
            box-shadow: 0 10px 30px var(--tdi-accent-glow);
        }

    .contact-icon {
        font-size: 3rem;
        margin-bottom: 20px;
    }

    .contact-form {
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--tdi-gray);
        border-radius: 15px;
        padding: 50px;
    }

    .form-control {
        background: rgba(255,255,255,0.1);
        border: 1px solid var(--tdi-gray);
        color: var(--tdi-light);
        border-radius: 8px;
        padding: 12px 15px;
        margin-bottom: 20px;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            background: rgba(255,255,255,0.15);
            border-color: var(--tdi-accent);
            color: var(--tdi-light);
            box-shadow: 0 0 0 0.2rem rgba(255,184,0,0.25);
        }

        .form-control::placeholder {
            color: rgba(255,255,255,0.6);
        }

    .form-label {
        color: var(--tdi-light);
        font-weight: 600;
        margin-bottom: 8px;
    }

    .response-time {
        background: rgba(255,184,0,0.1);
        border: 1px solid var(--tdi-accent);
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        margin: 30px 0;
    }

    .guarantee-badge {
        background: var(--tdi-accent);
        color: var(--tdi-dark);
        padding: 10px 20px;
        border-radius: 25px;
        font-weight: 700;
        display: inline-block;
        margin: 10px 0;
    }

    /* FIXED BUTTON - NOT FADED */
    .btn-contact-primary {
        background: linear-gradient(135deg, var(--tdi-accent) 0%, var(--tdi-accent-dark) 100%);
        color: var(--tdi-dark);
        border: none;
        font-weight: 700;
        padding: 14px 35px;
        border-radius: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .btn-contact-primary::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }

        .btn-contact-primary:hover::before {
            left: 100%;
        }

        .btn-contact-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px var(--tdi-accent-glow);
        }
</style>

<!-- Hero Section -->
<section class="contact-hero">
    <div class="container">
        <h1 class="display-1 gold-text mb-4">Let's Build Something Great</h1>
        <p class="lead fs-3 mb-4">Ready to build? Tell us what you need done — immediately.</p>
        <p class="fs-5">We respond within 1 hour during business hours. Your project starts the moment we connect.</p>
    </div>
</section>

<!-- Contact Methods - MOVED UP -->
<section class="py-5">
    <div class="container py-5">
        <div class="contact-methods">
            <!-- WhatsApp -->
            <div class="contact-card">
                <div class="contact-icon">💬</div>
                <h3 class="gold-text mb-3">WhatsApp Chat</h3>
                <p class="mb-4">Fastest way to get started. Send us a message and we'll respond immediately.</p>
                <a href="https://wa.me/+27763621131?text=Hi! I'm interested in your services and would like to discuss my project"
                   class="btn btn-tdi-outline" target="_blank">
                    Start Chat on WhatsApp
                </a>
                <p class="mt-3 text-muted">Typically respond in minutes</p>
            </div>

            <!-- Email -->
            <div class="contact-card">
                <div class="contact-icon">✉️</div>
                <h3 class="gold-text mb-3">Email Us</h3>
                <p class="mb-4">Prefer email? Send us your project details and we'll get back to you with a proposal.</p>
                <a href="mailto:goodenough245@gmail.com?subject=Project Inquiry&body=Hi! I'd like to discuss my project requirements."
                   class="btn btn-tdi-outline">
                    Send Email
                </a>
                <p class="mt-3 text-muted">Response within 2 hours</p>
            </div>

            <!-- Project Form -->
            <div class="contact-card">
                <div class="contact-icon">📋</div>
                <h3 class="gold-text mb-3">Project Brief</h3>
                <p class="mb-4">Have a detailed project? Fill out our brief form for a comprehensive quote.</p>
                <a href="#project-form" class="btn btn-tdi-outline">
                    Fill Project Brief
                </a>
                <p class="mt-3 text-muted">Detailed proposal within 24 hours</p>
            </div>
        </div>

        <!-- Response Time Guarantee - MOVED BELOW -->
        <div class="response-time">
            <h3 class="gold-text mb-3">🚀 Immediate Response Guarantee</h3>
            <p class="mb-3">We live up to our name. Contact us now and get a response within 1 hour during business hours.</p>
            <div class="guarantee-badge">1-HOUR RESPONSE TIME</div>
        </div>
    </div>
</section>

<!-- Contact Form -->
<section class="py-5" style="background: rgba(255,184,0,0.05);" id="project-form">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="contact-form">
                    <h2 class="gold-text text-center mb-5">Tell Us About Your Project</h2>

                    <form id="projectContactForm">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="firstName" class="form-label">First Name *</label>
                                    <input type="text" class="form-control" id="firstName" name="firstName" required placeholder="Your first name">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="lastName" class="form-label">Last Name *</label>
                                    <input type="text" class="form-control" id="lastName" name="lastName" required placeholder="Your last name">
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="email" class="form-label">Email *</label>
                                    <input type="email" class="form-control" id="email" name="email" required placeholder="your.email@example.com">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="phone" class="form-label">Phone</label>
                                    <input type="tel" class="form-control" id="phone" name="phone" placeholder="+1 (555) 123-4567">
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="company" class="form-label">Company / Business</label>
                            <input type="text" class="form-control" id="company" name="company" placeholder="Your business name">
                        </div>

                        <div class="form-group">
                            <label for="service" class="form-label">Service Interested In *</label>
                            <select class="form-control" id="service" name="service" required>
                                <option value="">Select a service...</option>
                                <option value="web-development">Web Development & Branding</option>
                                <option value="automation">AI Automation & Systems</option>
                                <option value="branding">Brand & Marketing Systems</option>
                                <option value="multiple">Multiple Services</option>
                                <option value="not-sure">Not Sure - Need Consultation</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="budget" class="form-label">Project Budget Range *</label>
                            <select class="form-control" id="budget" name="budget" required>
                                <option value="">Select budget range...</option>
                                <option value="1k-3k">$1,000 - $3,000</option>
                                <option value="3k-7k">$3,000 - $7,000</option>
                                <option value="7k-15k">$7,000 - $15,000</option>
                                <option value="15k-plus">$15,000+</option>
                                <option value="not-sure">Not Sure - Need Quote</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="timeline" class="form-label">Desired Timeline *</label>
                            <select class="form-control" id="timeline" name="timeline" required>
                                <option value="">Select timeline...</option>
                                <option value="immediately">Immediately (ASAP)</option>
                                <option value="2-weeks">Within 2 Weeks</option>
                                <option value="1-month">Within 1 Month</option>
                                <option value="flexible">Flexible Timeline</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="message" class="form-label">Project Details *</label>
                            <textarea class="form-control" id="message" name="message" rows="5" required placeholder="Tell us about your project goals, challenges, and what you'd like to achieve..."></textarea>
                        </div>

                        <div class="text-center mt-4">
                            <!-- FIXED BUTTON - NOT FADED -->
                            <button type="submit" class="btn-contact-primary btn-lg">
                                🚀 Send Project Brief
                            </button>
                            <p class="mt-3 text-muted">We'll get back to you within 1 hour during business hours</p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Final CTA - CLEANED UP -->
<section class="py-5 text-center">
    <div class="container py-5">
        <h2 class="gold-text mb-4">Don't Wait. Automate.</h2>
        <p class="lead mb-5">Every day you wait is another day of manual work, missed opportunities, and growth left on the table.</p>

        <a href="https://wa.me/+27763621131?text=Hi! I'm ready to start my project immediately. Let's talk!"
           class="btn btn-tdi-outline btn-lg" target="_blank">
            💬 Start WhatsApp Chat Now
        </a>
    </div>
</section>

@section Scripts {
    <script>
                document.getElementById('projectContactForm').addEventListener('submit', function(e) {
                    e.preventDefault();

                    // Get form data
                    const formData = {
                        firstName: document.getElementById('firstName').value,
                        lastName: document.getElementById('lastName').value,
                        email: document.getElementById('email').value,
                        phone: document.getElementById('phone').value,
                        company: document.getElementById('company').value,
                        service: document.getElementById('service').value,
                        budget: document.getElementById('budget').value,
                        timeline: document.getElementById('timeline').value,
                        message: document.getElementById('message').value
                    };

                    // Create WhatsApp message
                    const whatsappMessage = `New Project Inquiry from TDI Website:

        Name: ${formData.firstName} ${formData.lastName}
        Email: ${formData.email}
        Phone: ${formData.phone}
        Company: ${formData.company}

        Service: ${formData.service}
        Budget: ${formData.budget}
        Timeline: ${formData.timeline}

        Project Details:
        ${formData.message}

        ---
        Sent via thingsdoneimmediately.xyz`;

                    // Encode message for URL
                    const encodedMessage = encodeURIComponent(whatsappMessage);

                    // Redirect to WhatsApp
                    window.open(`https://wa.me/+27763621131?text=${encodedMessage}`, '_blank');

                    // Show success message
                    alert('Thank you! Redirecting to WhatsApp to send your project details...');
                });
    </script>
}