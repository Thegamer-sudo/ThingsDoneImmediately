@{
    ViewData["Title"] = "AI Automation - Things Done Immediately";
}

<style>
    .automation-hero {
        background: linear-gradient(135deg, var(--tdi-dark) 0%, var(--tdi-darker) 100%);
        padding: 150px 0 100px;
        text-align: center;
    }

    .flow-diagram {
        background: rgba(255,215,0,0.05);
        border: 2px solid var(--tdi-accent);
        padding: 40px;
        border-radius: 10px;
        margin: 40px 0;
    }

    .flow-step {
        display: flex;
        align-items: center;
        margin: 20px 0;
        padding: 20px;
        background: rgba(255,255,255,0.05);
        border-radius: 8px;
    }

    .flow-arrow {
        color: var(--tdi-accent);
        font-size: 2rem;
        margin: 0 20px;
    }

    .tool-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,215,0,0.3);
        border-radius: 10px;
        padding: 25px;
        text-align: center;
        height: 100%;
        transition: all 0.3s ease;
    }

        .tool-card:hover {
            border-color: var(--tdi-accent);
            transform: translateY(-5px);
        }

    .tool-icon {
        font-size: 2.5rem;
        margin-bottom: 15px;
    }

    .use-case {
        background: rgba(255,255,255,0.03);
        border-left: 4px solid var(--tdi-accent);
        padding: 25px;
        margin: 20px 0;
    }

    /* SOLID BUTTON STYLES */
    .btn-contact-primary {
        background: linear-gradient(135deg, var(--tdi-accent) 0%, var(--tdi-accent-dark) 100%);
        color: var(--tdi-dark);
        border: none;
        font-weight: 700;
        padding: 14px 35px;
        border-radius: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .btn-contact-primary::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }

        .btn-contact-primary:hover::before {
            left: 100%;
        }

        .btn-contact-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px var(--tdi-accent-glow);
        }
</style>

