@{
    ViewData["Title"] = "Brand & Marketing - Things Done Immediately";
}

<style>
    .branding-hero {
        background: linear-gradient(135deg, var(--tdi-dark) 0%, var(--tdi-darker) 100%);
        padding: 150px 0 100px;
        text-align: center;
    }

    .brand-pillar {
        text-align: center;
        padding: 40px 20px;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--tdi-gray);
        border-radius: 10px;
        height: 100%;
        transition: all 0.3s ease;
    }

        .brand-pillar:hover {
            border-color: var(--tdi-accent);
            transform: translateY(-5px);
        }

    .pillar-icon {
        font-size: 3rem;
        margin-bottom: 20px;
    }

    .social-platform {
        background: rgba(255,255,255,0.05);
        border-radius: 10px;
        padding: 25px;
        margin: 15px 0;
        border-left: 4px solid var(--tdi-accent);
    }

    /* SOLID BUTTON STYLES */
    .btn-contact-primary {
        background: linear-gradient(135deg, var(--tdi-accent) 0%, var(--tdi-accent-dark) 100%);
        color: var(--tdi-dark);
        border: none;
        font-weight: 700;
        padding: 14px 35px;
        border-radius: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .btn-contact-primary::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }

        .btn-contact-primary:hover::before {
            left: 100%;
        }

        .btn-contact-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px var(--tdi-accent-glow);
        }
</style>

