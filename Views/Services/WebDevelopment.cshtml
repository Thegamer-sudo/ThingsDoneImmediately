@{
    ViewData["Title"] = "Web Development - Things Done Immediately";
}

<style>
    .service-hero {
        background: linear-gradient(135deg, var(--tdi-dark) 0%, var(--tdi-darker) 100%);
        padding: 150px 0 100px;
        text-align: center;
    }

    .feature-icon {
        width: 80px;
        height: 80px;
        background: rgba(255,215,0,0.1);
        border: 2px solid var(--tdi-accent);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 2rem;
    }

    .process-step {
        position: relative;
        padding-left: 80px;
        margin-bottom: 40px;
    }

    .step-number {
        position: absolute;
        left: 0;
        top: 0;
        width: 60px;
        height: 60px;
        background: var(--tdi-accent);
        color: var(--tdi-dark);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 700;
        font-family: 'Bebas Neue';
    }

    .portfolio-item {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,215,0,0.2);
        padding: 30px;
        margin-bottom: 30px;
        transition: all 0.3s ease;
    }

        .portfolio-item:hover {
            border-color: var(--tdi-accent);
            transform: translateY(-5px);
        }

    /* SOLID BUTTON STYLES */
    .btn-contact-primary {
        background: linear-gradient(135deg, var(--tdi-accent) 0%, var(--tdi-accent-dark) 100%);
        color: var(--tdi-dark);
        border: none;
        font-weight: 700;
        padding: 14px 35px;
        border-radius: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .btn-contact-primary::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }

        .btn-contact-primary:hover::before {
            left: 100%;
        }

        .btn-contact-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px var(--tdi-accent-glow);
        }
</style>

<!-- Service Hero -->
<section class="service-hero">
    <div class="container">
        <h1 class="display-1 gold-text mb-4">Web Development</h1>
        <p class="lead fs-3 mb-4">Your Online Presence Is Your First Impression</p>
        <p class="fs-5 mb-5">Engage more clients, look professional, and scale globally with custom websites that convert.</p>
        <a href="https://wa.me/+27763621131?text=Hi! I'm interested in web development services"
           class="btn btn-contact-primary btn-lg" target="_blank">
            🌐 Start My Project
        </a>
    </div>
</section>

