@{
    ViewData["Title"] = "Success Stories - Things Done Immediately";
}

<style>
    .case-study {
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--tdi-gray);
        border-radius: 15px;
        padding: 40px;
        margin: 40px 0;
        transition: all 0.3s ease;
    }

        .case-study:hover {
            border-color: var(--tdi-accent);
        }

    .expandable-section {
        margin: 25px 0;
    }

    .expand-toggle {
        background: rgba(255,184,0,0.1);
        border: 1px solid var(--tdi-accent);
        color: var(--tdi-accent);
        padding: 12px 25px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

        .expand-toggle:hover {
            background: var(--tdi-accent);
            color: var(--tdi-dark);
        }

    .expand-content {
        display: none;
        padding: 25px;
        background: rgba(42,42,42,0.6);
        border-radius: 10px;
        margin-top: 15px;
        border-left: 4px solid var(--tdi-accent);
    }

    .tech-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin: 20px 0;
    }

    .tech-badge {
        background: rgba(255,184,0,0.2);
        color: var(--tdi-accent);
        padding: 8px 15px;
        border-radius: 20px;
        border: 1px solid var(--tdi-accent);
        font-size: 0.9rem;
    }
</style>

<!-- Hero Section - FIXED HEADER SPACING -->
<section class="testimonials-hero" style="padding: 150px 0 100px;">
    <div class="container">
        <h1 class="display-1 gold-text mb-4">Real Work. Real Results.</h1>
        <p class="lead fs-3 mb-4">See how we deliver immediate value to businesses</p>
    </div>
</section>

<!-- Elite Health Club Case Study -->
<section class="py-5">
    <div class="container py-5">
        <div class="case-study">
            <div class="row align-items-center mb-4">
                <div class="col-lg-8">
                    <h2 class="gold-text mb-3">Elite Health Club</h2>
                    <p class="fs-5">Complete digital transformation for a premium fitness center</p>
                </div>
            </div>

            <!-- The Challenge - Expandable -->
            <div class="expandable-section">
                <div class="expand-toggle" onclick="toggleSection('challenge')">
                    <span>📋 The Challenge</span>
                    <span>+</span>
                </div>
                <div class="expand-content" id="challenge">
                    <p>Elite Health Club needed to modernize their entire digital presence to handle growing membership demands and streamline their operations.</p>
                    <ul>
                        <li>Outdated website hurting credibility</li>
                        <li>Manual membership processing causing delays</li>
                        <li>No online booking system for classes</li>
                        <li>Inefficient payment collection methods</li>
                        <li>Poor member communication systems</li>
                    </ul>
                </div>
            </div>

            <!-- Our Solution - Expandable -->
            <div class="expandable-section">
                <div class="expand-toggle" onclick="toggleSection('solution')">
                    <span>🛠️ What We Built</span>
                    <span>+</span>
                </div>
                <div class="expand-content" id="solution">
                    <p>We delivered a complete digital ecosystem tailored to their specific needs:</p>

                    <div class="tech-stack">
                        <span class="tech-badge">ASP.NET Core MVC</span>
                        <span class="tech-badge">Bootstrap 5</span>
                        <span class="tech-badge">Custom Booking System</span>
                        <span class="tech-badge">Member Portal</span>
                        <span class="tech-badge">Payment Integration</span>
                        <span class="tech-badge">Email Automation</span>
                    </div>

                    <div class="row mt-4">
                        <div class="col-md-6">
                            <h5 class="gold-text">Custom Website</h5>
                            <p>Modern, responsive design showcasing facilities and services with optimized user experience.</p>
                        </div>
                        <div class="col-md-6">
                            <h5 class="gold-text">Membership System</h5>
                            <p>Secure member area with profile management, payment history, and class scheduling.</p>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <h5 class="gold-text">Booking Engine</h5>
                            <p>Real-time class scheduling with capacity management and automatic reminders.</p>
                        </div>
                        <div class="col-md-6">
                            <h5 class="gold-text">Admin Dashboard</h5>
                            <p>Complete backend system for managing members, classes, payments, and communications.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- The Result - Expandable -->
            <div class="expandable-section">
                <div class="expand-toggle" onclick="toggleSection('result')">
                    <span>🎯 The Outcome</span>
                    <span>+</span>
                </div>
                <div class="expand-content" id="result">
                    <p>The transformation led to significant operational improvements and member satisfaction.</p>

                    <div class="row mt-4">
                        <div class="col-md-6">
                            <h5 class="gold-text">Operational Efficiency</h5>
                            <p>Dramatically reduced administrative workload through automation and streamlined processes.</p>
                        </div>
                        <div class="col-md-6">
                            <h5 class="gold-text">Member Experience</h5>
                            <p>Seamless digital experience from signup to class booking and payments.</p>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <h5 class="gold-text">Business Growth</h5>
                            <p>Enhanced digital presence attracted new members and improved retention.</p>
                        </div>
                        <div class="col-md-6">
                            <h5 class="gold-text">Ongoing Partnership</h5>
                            <p>Continued collaboration for maintenance and feature enhancements.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Client Testimonial -->
        <div class="text-center mt-5">
            <h3 class="gold-text mb-4">What Our Client Says</h3>
            <div class="testimonial-card">
                <p class="fs-5 mb-4">"Things Done Immediately delivered exactly what we needed - a professional, functional website that works for our business. The attention to detail and understanding of our specific requirements was impressive."</p>
                <h5 class="gold-text mb-1">[Client Name]</h5>
                <p class="mb-0">[Position], Elite Health Club</p>
                <p class="text-muted mt-2">*Actual client details available upon request</p>
            </div>
        </div>
    </div>
</section>

<!-- Coming Soon Projects -->
<section class="py-5" style="background: rgba(255,184,0,0.05);">
    <div class="container py-5">
        <div class="row text-center">
            <div class="col-12">
                <h2 class="gold-text mb-4">More Case Studies Coming Soon</h2>
                <p class="lead mb-5">We're continuously delivering value to businesses across industries</p>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="portfolio-item text-center">
                    <h5 class="gold-text">Restaurant Booking System</h5>
                    <p class="text-muted">Launching next month</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="portfolio-item text-center">
                    <h5 class="gold-text">AI Customer Service</h5>
                    <p class="text-muted">Case study in progress</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="portfolio-item text-center">
                    <h5 class="gold-text">E-commerce Automation</h5>
                    <p class="text-muted">Coming soon</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function toggleSection(sectionId) {
            const content = document.getElementById(sectionId);
            const toggle = content.previousElementSibling;
            const plusMinus = toggle.querySelector('span:last-child');

            if (content.style.display === 'block') {
                content.style.display = 'none';
                plusMinus.textContent = '+';
            } else {
                content.style.display = 'block';
                plusMinus.textContent = '-';
            }
        }
    </script>
}